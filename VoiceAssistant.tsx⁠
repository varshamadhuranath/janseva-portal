'use client';
import React, { useState, useEffect } from 'react';

export function VoiceAssistant({ text, lang }: { text: string; lang: 'en' | 'hi' | 'kn' }) {
  const [speaking, setSpeaking] = useState(false);

  const speak = () => {
    if (typeof window === 'undefined' || !window.speechSynthesis) return;
    window.speechSynthesis.cancel();
    const utterance = new SpeechSynthesisUtterance(text);
    utterance.lang = lang === 'hi' ? 'hi-IN' : lang === 'kn' ? 'kn-IN' : 'en-IN';
    utterance.rate = 0.85; // Speak clearly and slowly
    utterance.onend = () => setSpeaking(false);
    setSpeaking(true);
    window.speechSynthesis.speak(utterance);
  };

  return (
    <button onClick={speak} className="w-full bg-indigo-600 text-white font-bold py-3 px-4 rounded-xl shadow flex items-center justify-center gap-2 text-base active:scale-95 transition-transform">
      {speaking ? '⏸️ Stop Voice' : '🔊 Tap to Listen (सुनें / ಆಲಿಸಿ)'}
    </button>
  );
}

export function FloatingMic({ lang, onCommand }: { lang: 'en' | 'hi' | 'kn'; onCommand: (cmd: string) => void }) {
  const [listening, setListening] = useState(false);

  const toggleMic = () => {
    const SpeechLib = (window as any).SpeechRecognition || (window as any).webkitSpeechRecognition;
    if (!SpeechLib) return;
    const rec = new SpeechLib();
    rec.lang = lang === 'hi' ? 'hi-IN' : lang === 'kn' ? 'kn-IN' : 'en-IN';
    
    rec.onstart = () => setListening(true);
    rec.onend = () => setListening(false);
    rec.onresult = (e: any) => {
      const result = e.results[0][0].transcript.toLowerCase();
      onCommand(result);
    };

    if (listening) rec.stop(); else rec.start();
  };

  return (
    <div className="fixed bottom-24 right-6 z-50 flex flex-col items-center">
      <button onClick={toggleMic} className={`w-16 h-16 rounded-full shadow-2xl text-2xl flex items-center justify-center font-bold text-white transition-all ${listening ? 'bg-rose-600 animate-ping' : 'bg-emerald-600'}`}>
        {listening ? '🛑' : '🎤'}
      </button>
      <span className="bg-slate-900 text-white text-[10px] font-bold mt-1 px-2 py-0.5 rounded">
        {listening ? 'Listening...' : 'Tap to Speak'}
      </span>
    </div>
  );
}
